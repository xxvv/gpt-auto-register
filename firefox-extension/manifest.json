{
  "manifest_version": 2,
  "name": "GPT Auto Register Helper",
  "version": "1.0.0",
  "description": "Firefox sidebar helper for email codes, Firefox proxy control, PayURL, and Stripe form filling.",
  "sidebar_action": {
    "default_title": "GPT Helper",
    "default_panel": "sidebar.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "proxy",
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "https://chatgpt.com/*",
    "https://getemail.nnai.website/*",
    "http://127.0.0.1:5000/*",
    "https://proxy.webshare.io/*",
    "https://payurl.779.chat/*",
    "https://www.meiguodizhi.com/*",
    "https://checkout.stripe.com/*",
    "https://*.stripe.com/*"
  ],
  "applications": {
    "gecko": {
      "id": "gpt-auto-register-helper@example.local",
      "strict_min_version": "109.0"
    }
  }
}
