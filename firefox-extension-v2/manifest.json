{
  "manifest_version": 2,
  "name": "GPT Auto Register v2",
  "version": "2.0.0",
  "description": "GPT registration, PayURL, and PayPal payment automation wizard",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "proxy",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "https://proxy.webshare.io/*",
    "https://ipapi.co/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "GPT Auto Register v2"
  },
  "applications": {
    "gecko": {
      "id": "gpt-auto-register-v2@example.local",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
