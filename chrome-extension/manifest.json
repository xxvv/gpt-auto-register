{
  "manifest_version": 3,
  "name": "GPT Auto Register Helper",
  "version": "1.0.0",
  "description": "Chrome side panel helper for email codes, Chrome proxy control, PayURL, and Stripe form filling.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "proxy",
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8888/*",
    "http://localhost:8888/*",
    "http://ip-api.com/*",
    "https://chatgpt.com/*",
    "https://getemail.nnai.website/*",
    "https://proxy.webshare.io/*",
    "https://payurl.779.chat/*",
    "https://checkout.stripe.com/*",
    "https://*.stripe.com/*"
  ],
  "action": {
    "default_title": "GPT Helper"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
